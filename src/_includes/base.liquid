<!DOCTYPE html>
<html lang="{{ metadata.language }}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content="{{ eleventy.generator }}">
    <meta name="description" content="{{ metadata.description }}">

    {%- comment -%} TODO: OpenGraph meta tags {% endcomment %}

    <link rel="canonical" href="{{ metadata.url }}{{ page.url }}">
    {%- comment -%} TODO: default to svg favicon {%- endcomment -%}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="manifest" href="/manifest.json">
    <link rel="alternate" type="application/rss+xml" href="/feed.xml">

    {%- css -%}
      {% include 'css/reset.css' %}
      {% include 'css/main.css' %}
      {% include 'css/prism.css' %}
    {% endcss %}
    <link rel="stylesheet" type="text/css" href="{% getBundleFileUrl 'css' %}" />

    <title>{{ metadata.author.name }} | {{ title }}</title>

    <script src="/js/analytics.js" defer></script>
    <script src="/js/script.js" defer></script>
  </head>
  <body>
    <a href="#main" id="skip-link">Skip to main content</a>
    <header>
      <a href="/">ryanmartin.me</a>
      <a href="/ctf" tabindex="-1">🚩👀⁉️</a>
      <nav>
        {% for link in site.header -%}
          <a href="{{ link.slug }}" {% if page.url == link.slug %}style="font-weight: bold"{% endif %}>{{ link.text }}</a>
        {% endfor -%}
      </nav>
    </header>
    <div id="top"></div>
    <main id="main">
      {% unless page.url != "/articles/" and page.url contains "/articles/"
                or
                page.url != "/drafts/" and page.url contains "/drafts/" %}
        <h1>{{ title }}</h1>
      {% endunless %}
      {{ content }}
    </main>
    <footer>
      <div>
        <p>&copy; 2024-{{ 'now' | date: '%Y' }} Ryan Martin. <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/">CC BY-NC-SA 4.0</a></p>
        <p><a href="#top">Back to top ⤴</a></p>
      </div>
      <p>
        <a href="/feed.xml">
          Subscribe
          <svg xmlns="http://www.w3.org/2000/svg" version="1.1" width="16" height="16" style="height: 1.2em; width: 1.2em; vertical-align: text-bottom" viewBox="0 0 256 256">
            <circle cx="68" cy="189" r="24" fill="currentColor"></circle>
            <path d="M160 213h-34a82 82 0 0 0 -82 -82v-34a116 116 0 0 1 116 116z" fill="currentColor"></path>
            <path d="M184 213A140 140 0 0 0 44 73 V 38a175 175 0 0 1 175 175z" fill="currentColor"></path>
          </svg>
          </a>
          <a href="https://aboutfeeds.com/">(What's this?)</a>
      </p>
      <p><a href="/colophon/">Colophon</a></p>
    </footer>
  </body>
</html>
